{
  "name": "commitdog",
  "version": "0.1.0",
  "description": "Local AI code review agent powered by OpenCode",
  "keywords": [
    "ai",
    "code-review",
    "git",
    "opencode",
    "pre-commit"
  ],
  "license": "MIT",
  "bin": {
    "commitdog": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && pnpm run typecheck",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.15.11",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ora": "^9.4.0",
    "picomatch": "^4.0.4",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.3",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.15.1"
}
