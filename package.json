{
  "name": "commitdog",
  "version": "0.1.0",
  "description": "🐕 Local AI code review agent powered by OpenCode",
  "type": "module",
  "bin": {
    "commitdog": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "code-review",
    "ai",
    "git",
    "opencode",
    "pre-commit"
  ],
  "license": "MIT",
  "dependencies": {
